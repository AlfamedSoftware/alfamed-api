{
  "name": "app",
  "version": "1.0.50",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "dev": "bun run --watch src/server.ts",
    "db:seed": "bun --env-file .env --bun src/scripts/seed-initial-admin.ts",
    "db:generate": "bun --env-file .env --bun drizzle-kit generate",
    "db:migrate": "bun --env-file .env --bun drizzle-kit migrate"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.2",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.27",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "drizzle-kit": "^0.31.8",
    "vitest": "^4.0.18"
  }
}