# Chave secreta usada pelo Better Auth para assinar tokens/sessao.
BETTER_AUTH_SECRET="your_better_auth_secret_here"
# URL base publica da API para callbacks e fluxos do Better Auth.
BETTER_AUTH_BASE_URL="http://localhost:3333"
# Email de remetente para envios do SendGrid.
SENDGRID_FROM_EMAIL="your_sendgrid_from_email_here"
# Chave de API do SendGrid para envio de emails.
SENDGRID_API_KEY="your_sendgrid_api_key_here"
# String de conexao com o banco PostgreSQL (Supabase).
DATABASE_URL="postgresql://user:password@host:5432/database"
